# PostgreSQL / PostGIS
POSTGRES_DB=taxi_vis
POSTGRES_USER=taxi_user
POSTGRES_PASSWORD=taxi_pass
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql+psycopg2://taxi_user:taxi_pass@localhost:5432/taxi_vis
REDIS_URL=redis://localhost:6379/0

# Frontend / AMap
# Vite only exposes variables prefixed with VITE_ to browser code.
# Required for both demo and full modes; the map will not load without them.
VITE_API_BASE_URL=http://localhost:8000
# true = frontend-only demo fixtures; false = call the real FastAPI backend.
VITE_DEMO_MODE=false
# Fill these in locally. Do not commit real AMap keys.
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_JS_CODE=

# Optional GPT / OpenAI-compatible relay
# Leave OPENAI_API_KEY empty to use the local Markdown RAG fallback only.
# For relay providers, set OPENAI_BASE_URL to the relay's /v1 endpoint.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_MODE=chat_completions
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=900
